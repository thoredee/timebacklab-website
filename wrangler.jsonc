{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "timebacklab-website",
  "compatibility_date": "2026-07-02",
  "observability": {
    "enabled": true
  },
  "main": "src/index.js",
  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "timebacklab-quiz",
      "database_id": "2300801d-c8a2-432c-b0cf-26d336782b75"
    }
  ]
}
